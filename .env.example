# Copy this file to .env and fill in your values.
# .env is excluded from version control via .gitignore.

# RapidAPI key for active-jobs-db.p.rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here

# PostgreSQL (only needed when running with --spring.profiles.active=prod)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobseeker
DB_USER=postgres
DB_PASSWORD=your_db_password_here
